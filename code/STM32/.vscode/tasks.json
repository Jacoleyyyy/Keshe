{
    "version": "2.0.0",
    "tasks": [

        // ============================================
        //  1. CMake 配置 (只需运行一次, 或在 CMakeLists.txt 变更后)
        // ============================================
        {
            "label": "CMake Configure (Ninja)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "build",
                "-G", "Ninja",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "CMake Configure (MinGW Make)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "build",
                "-G", "\"MinGW Makefiles\"",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ============================================
        //  2. 编译 (Ctrl+Shift+B)
        //     CMake --build 自动检测生成器
        // ============================================
        {
            "label": "Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "-j8"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "c",
                "fileLocation": ["absolute"],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(fatal error|error|warning):\\s+(.*)$",
                    "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
                }
            },
            "presentation": {
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },

        // ============================================
        //  3. 清理
        // ============================================
        {
            "label": "Clean",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "--target", "clean"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": { "reveal": "silent", "panel": "shared" }
        },

        // ============================================
        //  4. 烧录 — pyOCD (推荐)
        // ============================================
        {
            "label": "Flash (pyOCD)",
            "type": "shell",
            "command": "pyocd",
            "args": [
                "load", "build/smart_carrier.hex",
                "--target", "stm32f407ve",
                "--frequency", "4000000"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "dependsOn": ["Build"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ============================================
        //  5. 烧录 — OpenOCD (备选)
        // ============================================
        {
            "label": "Flash (OpenOCD)",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "interface/stlink.cfg",
                "-f", "target/stm32f4x.cfg",
                "-c", "program build/smart_carrier verify reset exit"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "dependsOn": ["Build"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ============================================
        //  6. 检查工具链是否可用
        // ============================================
        {
            "label": "Check Toolchain",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "echo '=== arm-none-eabi-gcc ===' && arm-none-eabi-gcc --version | head -1 && echo '' && echo '=== cmake ===' && cmake --version | head -1 && echo '' && echo '=== ninja ===' && ninja --version 2>/dev/null || echo 'ninja not found' && echo '' && echo '=== pyocd ===' && pyocd --version 2>/dev/null || echo 'pyocd not found' && echo '' && echo '=== openocd ===' && openocd --version 2>&1 | head -1 || echo 'openocd not found' && echo '' && echo '=== arm-none-eabi-gdb ===' && arm-none-eabi-gdb --version | head -1 || echo 'arm-none-eabi-gdb not found'"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated" }
        },

        // ============================================
        //  7. 编译 + 烧录 (一键)
        // ============================================
        {
            "label": "Build & Flash",
            "type": "shell",
            "dependsOrder": "sequence",
            "dependsOn": ["Build", "Flash (pyOCD)"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ============================================
        //  8. 全清理 (删除 build/ 目录)
        // ============================================
        {
            "label": "Clean All",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "rm -rf build && echo 'build/ deleted'"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": { "reveal": "silent", "panel": "shared" }
        }
    ]
}
