{
    // ============================================
    // 默认使用 ARM GCC 编译
    // ============================================
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",

    // 文件关联
    "files.associations": {
        "*.h": "c",
        "*.c": "c",
        "cmsis_os.h": "c",
        "FreeRTOS.h": "c",
        "task.h": "c",
        "queue.h": "c",
        "semphr.h": "c",
        "portmacro.h": "c",
        "stm32f4xx_hal.h": "c",
        "stm32f4xx_hal_conf.h": "c",
        "gpio.h": "c",
        "rcc.h": "c",
        "tim.h": "c",
        "usart.h": "c",
        "i2c.h": "c",
        "system_stm32f4xx.h": "c"
    },

    // Cortex-Debug 设置
    "cortex-debug.variableUseNaturalFormat": true,
    "cortex-debug.registerUseNaturalFormat": true,
    "cortex-debug.displayDemangled": true,
    "cortex-debug.showRTOSDebugOutput": true,
    "cortex-debug.armToolchainPath": "C:/Program Files (x86)/Arm GNU Toolchain arm-none-eabi/13.3.rel1/bin",

    // 编辑器设置
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [100],
    "editor.formatOnSave": false,

    // 文件排除 (不显示编译产物)
    "files.exclude": {
        "build": true
    },

    // 搜索排除
    "search.exclude": {
        "build/**": true,
        "Drivers/**": false
    }
}
